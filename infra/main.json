{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "13419834314170589631"
    }
  },
  "parameters": {
    "appName": {
      "type": "string",
      "defaultValue": "recoverynote",
      "metadata": {
        "description": "Base name used to derive all resource names."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region. Defaults to the resource group's location."
      }
    },
    "postgresAdminUser": {
      "type": "string",
      "defaultValue": "pgadmin",
      "metadata": {
        "description": "PostgreSQL administrator login name."
      }
    },
    "postgresAdminPassword": {
      "type": "securestring",
      "minLength": 8,
      "metadata": {
        "description": "PostgreSQL administrator password. Must not contain @ or ? characters."
      }
    },
    "secretKey": {
      "type": "securestring",
      "minLength": 16,
      "metadata": {
        "description": "Flask SECRET_KEY value. Use a long random string (32+ characters recommended)."
      }
    },
    "deployerObjectId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Object ID of the identity running this deployment. Grants it Key Vault Secrets Officer so secrets can be written during deployment. Get with: az ad signed-in-user show --query id -o tsv. Leave empty if you have already pre-assigned Key Vault Secrets Officer on the vault."
      }
    },
    "postgresSkuName": {
      "type": "string",
      "defaultValue": "Standard_B1ms",
      "allowedValues": [
        "Standard_B1ms",
        "Standard_B2ms",
        "Standard_D2s_v3"
      ],
      "metadata": {
        "description": "PostgreSQL Flexible Server SKU. Change if B1ms capacity is unavailable in your region (e.g. Standard_B2ms)."
      }
    },
    "deployWiki": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Whether to deploy the client-llm-wiki Node.js app alongside RecoveryNote."
      }
    },
    "wikiAuthSecret": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "NextAuth secret for client-llm-wiki. Use: openssl rand -base64 32"
      }
    },
    "wikiAnthropicApiKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Anthropic API key for client-llm-wiki AI features."
      }
    }
  },
  "variables": {
    "suffix": "[take(uniqueString(resourceGroup().id), 8)]",
    "planName": "[format('{0}-plan', parameters('appName'))]",
    "webAppName": "[format('{0}-{1}', parameters('appName'), variables('suffix'))]",
    "wikiAppName": "[format('clientwiki-{0}', variables('suffix'))]",
    "kvName": "[format('{0}-kv-{1}', take(parameters('appName'), 10), take(variables('suffix'), 6))]",
    "pgServerName": "[format('{0}-pg-{1}', take(toLower(parameters('appName')), 15), variables('suffix'))]",
    "dbName": "recoverynote",
    "wikiDbName": "clientllmwiki"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('planName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": {
        "name": "B1",
        "tier": "Basic"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "PYTHON|3.12",
          "alwaysOn": true,
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]"
      ]
    },
    {
      "condition": "[parameters('deployWiki')]",
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('wikiAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "NODE|18-lts",
          "alwaysOn": true,
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "appCommandLine": "node server.js"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('kvName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "tenantId": "[subscription().tenantId]",
        "enableRbacAuthorization": false,
        "softDeleteRetentionInDays": 7,
        "enableSoftDelete": true,
        "accessPolicies": "[concat(if(not(empty(parameters('deployerObjectId'))), createArray(createObject('tenantId', subscription().tenantId, 'objectId', parameters('deployerObjectId'), 'permissions', createObject('secrets', createArray('get', 'list', 'set', 'delete')))), createArray()), createArray(createObject('tenantId', subscription().tenantId, 'objectId', reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-12-01', 'full').identity.principalId, 'permissions', createObject('secrets', createArray('get', 'list')))), if(parameters('deployWiki'), createArray(createObject('tenantId', subscription().tenantId, 'objectId', reference(resourceId('Microsoft.Web/sites', variables('wikiAppName')), '2023-12-01', 'full').identity.principalId, 'permissions', createObject('secrets', createArray('get', 'list')))), createArray()))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('webAppName'))]",
        "[resourceId('Microsoft.Web/sites', variables('wikiAppName'))]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers",
      "apiVersion": "2023-06-01-preview",
      "name": "[variables('pgServerName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('postgresSkuName')]",
        "tier": "Burstable"
      },
      "properties": {
        "administratorLogin": "[parameters('postgresAdminUser')]",
        "administratorLoginPassword": "[parameters('postgresAdminPassword')]",
        "version": "16",
        "storage": {
          "storageSizeGB": 32
        },
        "backup": {
          "backupRetentionDays": 7,
          "geoRedundantBackup": "Disabled"
        },
        "highAvailability": {
          "mode": "Disabled"
        },
        "authConfig": {
          "activeDirectoryAuth": "Disabled",
          "passwordAuth": "Enabled"
        }
      }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2023-06-01-preview",
      "name": "[format('{0}/{1}', variables('pgServerName'), variables('dbName'))]",
      "properties": {
        "charset": "UTF8",
        "collation": "en_US.utf8"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgServerName'))]"
      ]
    },
    {
      "condition": "[parameters('deployWiki')]",
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2023-06-01-preview",
      "name": "[format('{0}/{1}', variables('pgServerName'), variables('wikiDbName'))]",
      "properties": {
        "charset": "UTF8",
        "collation": "en_US.utf8"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgServerName'))]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
      "apiVersion": "2023-06-01-preview",
      "name": "[format('{0}/{1}', variables('pgServerName'), 'AllowAllAzureServicesAndResourcesWithinAzureIps')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgServerName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('kvName'), 'database-url')]",
      "properties": {
        "value": "[format('postgresql://{0}:{1}@{2}:5432/{3}?sslmode=require', parameters('postgresAdminUser'), parameters('postgresAdminPassword'), reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgServerName')), '2023-06-01-preview').fullyQualifiedDomainName, variables('dbName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgServerName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('kvName'), 'secret-key')]",
      "properties": {
        "value": "[parameters('secretKey')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    },
    {
      "condition": "[parameters('deployWiki')]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('kvName'), 'wiki-database-url')]",
      "properties": {
        "value": "[format('postgresql://{0}:{1}@{2}:5432/{3}?sslmode=require', parameters('postgresAdminUser'), parameters('postgresAdminPassword'), reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgServerName')), '2023-06-01-preview').fullyQualifiedDomainName, variables('wikiDbName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgServerName'))]"
      ]
    },
    {
      "condition": "[and(parameters('deployWiki'), not(empty(parameters('wikiAuthSecret'))))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('kvName'), 'wiki-auth-secret')]",
      "properties": {
        "value": "[parameters('wikiAuthSecret')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    },
    {
      "condition": "[and(parameters('deployWiki'), not(empty(parameters('wikiAnthropicApiKey'))))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('kvName'), 'wiki-anthropic-api-key')]",
      "properties": {
        "value": "[parameters('wikiAnthropicApiKey')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', variables('webAppName'), 'appsettings')]",
      "properties": {
        "SCM_DO_BUILD_DURING_DEPLOYMENT": "true",
        "DATABASE_URL": "[format('@Microsoft.KeyVault(VaultName={0};SecretName=database-url)', variables('kvName'))]",
        "SECRET_KEY": "[format('@Microsoft.KeyVault(VaultName={0};SecretName=secret-key)', variables('kvName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('kvName'), 'secret-key')]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('kvName'), 'database-url')]",
        "[resourceId('Microsoft.Web/sites', variables('webAppName'))]"
      ]
    },
    {
      "condition": "[parameters('deployWiki')]",
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', variables('wikiAppName'), 'appsettings')]",
      "properties": {
        "SCM_DO_BUILD_DURING_DEPLOYMENT": "true",
        "DATABASE_URL": "[format('@Microsoft.KeyVault(VaultName={0};SecretName=wiki-database-url)', variables('kvName'))]",
        "AUTH_SECRET": "[format('@Microsoft.KeyVault(VaultName={0};SecretName=wiki-auth-secret)', variables('kvName'))]",
        "ANTHROPIC_API_KEY": "[format('@Microsoft.KeyVault(VaultName={0};SecretName=wiki-anthropic-api-key)', variables('kvName'))]",
        "NEXTAUTH_URL": "[format('https://{0}.azurewebsites.net', variables('wikiAppName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('kvName'), 'wiki-anthropic-api-key')]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('kvName'), 'wiki-auth-secret')]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('kvName'), 'wiki-database-url')]",
        "[resourceId('Microsoft.Web/sites', variables('wikiAppName'))]"
      ]
    }
  ],
  "outputs": {
    "webAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-12-01').defaultHostName)]"
    },
    "webAppName": {
      "type": "string",
      "value": "[variables('webAppName')]"
    },
    "wikiAppUrl": {
      "type": "string",
      "value": "[if(parameters('deployWiki'), format('https://{0}', reference(resourceId('Microsoft.Web/sites', variables('wikiAppName')), '2023-12-01').defaultHostName), '')]"
    },
    "wikiAppName": {
      "type": "string",
      "value": "[if(parameters('deployWiki'), variables('wikiAppName'), '')]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[variables('kvName')]"
    },
    "postgresServerFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgServerName')), '2023-06-01-preview').fullyQualifiedDomainName]"
    }
  }
}
